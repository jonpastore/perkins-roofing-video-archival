# Databases & downloaded media (large, regenerable)
*.db
poc/data/

# Python caches
__pycache__/
*.pyc
.pytest_cache/
*.egg-info/
.venv/
venv/

# Logs
logs/
*.log

# Local tooling state
.omc/
.claude/

# SPA build artifacts
web/node_modules/
web/dist/

# Env / secrets
*.env
.env*
# GCP service-account keys — NEVER commit
*-sa.json
infra/vertex-dev-sa.json

# Coverage + Terraform local state (keep .terraform.lock.hcl tracked)
.coverage
infra/.terraform/
*.tfstate
*.tfstate.*

# Terraform var files with secrets (OAuth client secret, etc.)
infra/terraform.tfvars
infra/*.auto.tfvars

# Firebase Hosting deploy cache (regenerated on every deploy)
web/.firebase/
