# Keep secrets, local state, and junk out of the Cloud Build context (`gcloud builds submit .`
# uploads the whole tree). The Dockerfile only COPYs core/adapters/api/jobs/app + requirements,
# but everything below still leaves the machine and slows builds if not excluded.
.git
.github
.venv
venv
**/__pycache__
*.pyc
.pytest_cache
.coverage
htmlcov

# Secrets / credentials — must never enter a build image
.env
.env.*
*.env
infra/vertex-dev-sa.json
**/*serviceaccount*.json
**/*-sa.json

# Local databases / data
*.db
poc/data

# Frontend build inputs (SPA is built + hosted separately via Firebase Hosting)
web/node_modules
web/dist

# Docs / infra / scripts not needed at runtime
docs
infra
ansible
scripts
tests
mockup
*.md

# ...but a few operational scripts DO run inside the image as Cloud Run Jobs.
# Re-include only those (order matters: un-ignore after the broad `scripts` ignore).
!scripts/
scripts/*
!scripts/render_proposal_pdfs_to_gcs.py
!scripts/migrate_knowify_quotes_to_proposals.py
!scripts/attach_knowify_contract_pdfs.py
!scripts/knowify_backfill_contacts_properties.py
